{
  "name": "oidc-auth-client",
  "version": "0.0.0",
  "description": "OpenID Connect (OIDC) and OAuth 2.0 client library for JavaScript applications - Consolidated & Refactored",
  "engines": {
    "node": ">=20.9.0"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:package": "node --input-type=module --eval \"import('./dist/index.js').then(m => { if (!m.UserManager) throw new Error('Missing UserManager'); console.log('package OK'); })\"",
    "prepublishOnly": "npm run build && npm run test:run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/src/auth/Client.d.ts",
      "import": "./dist/src/auth/Client.js"
    },
    "./protocol": {
      "types": "./dist/src/protocol/TokenService.d.ts",
      "import": "./dist/src/protocol/TokenService.js"
    },
    "./storage": {
      "types": "./dist/src/storage/Storage.d.ts",
      "import": "./dist/src/storage/Storage.js"
    },
    "./utils": {
      "types": "./dist/src/utils/Log.d.ts",
      "import": "./dist/src/utils/Log.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "base64-js": "^1.5.1",
    "crypto-js": "^4.2.0",
    "jsbn": "^1.1.0",
    "jsdom": "^27.2.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.15",
    "typescript": "^6.0.2",
    "vitest": "^4.0.15"
  },
  "keywords": [
    "oidc",
    "openid-connect",
    "oauth2",
    "authentication",
    "authorization",
    "jwt",
    "identity",
    "sso",
    "single-sign-on",
    "pkce",
    "implicit-flow",
    "authorization-code",
    "javascript",
    "browser",
    "client"
  ],
  "homepage": "https://github.com/callezenwaka/oidc-client#readme",
  "bugs": {
    "url": "https://github.com/callezenwaka/oidc-client/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/callezenwaka/oidc-client.git"
  },
  "author": {
    "name": "Callis Ezenwaka",
    "email": "callisezenwaka@outlook.com"
  },
  "license": "Apache-2.0"
}
